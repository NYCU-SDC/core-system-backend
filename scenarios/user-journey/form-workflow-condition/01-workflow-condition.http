###

# ============================================
# Update Workflow: START -> Section A -> Condition1 -> [Section B / Condition2] -> Condition2 -> [Section C / END]
# ============================================
# Condition1: pattern includes choice B id -> nextTrue Section B, else nextFalse Condition2
# Condition2: pattern includes choice C id -> nextTrue Section C, else nextFalse END (error handling)
# Pattern is "include" (no ^ $): matches when value contains the choice id
# @name updateWorkflowWithConditionBranches
# @ref createCondition2Node
PUT {{BASE_URL}}/forms/{{formId}}/workflow
Content-Type: application/json

[
    {
        "id": "{{startNodeId}}",
        "label": "開始表單",
        "payload": { "x": 0.0, "y": 0.0 },
        "next": "{{sectionNodeId}}"
    },
    {
        "id": "{{sectionNodeId}}",
        "label": "{{sectionNodeLabel}}",
        "payload": { "x": 1.0, "y": 2.0 },
        "next": "{{conditionNodeId}}"
    },
    {
        "id": "{{conditionNodeId}}",
        "label": "If choose Team B",
        "payload": { "x": 2.0, "y": 2.0 },
        "conditionRule": {
            "source": "CHOICE",
            "question": "{{sectionAQuestionId}}",
            "pattern": "{{sectionAChoiceSectionBId}}"
        },
        "nextTrue": "{{sectionBNodeId}}",
        "nextFalse": "{{condition2NodeId}}"
    },
    {
        "id": "{{condition2NodeId}}",
        "label": "If choose Team C",
        "payload": { "x": 3.0, "y": 2.0 },
        "conditionRule": {
            "source": "CHOICE",
            "question": "{{sectionAQuestionId}}",
            "pattern": "{{sectionAChoiceSectionCId}}"
        },
        "nextTrue": "{{sectionCNodeId}}",
        "nextFalse": "{{endNodeId}}"
    },
    {
        "id": "{{sectionBNodeId}}",
        "label": "Section B",
        "payload": { "x": 2.0, "y": 3.0 },
        "next": "{{condition2NodeId}}"
    },
    {
        "id": "{{sectionCNodeId}}",
        "label": "Section C",
        "payload": { "x": 3.0, "y": 3.0 },
        "next": "{{endNodeId}}"
    },
    {
        "id": "{{endNodeId}}",
        "label": "確認/送出",
        "payload": { "x": 0.0, "y": 1.0 }
    }
]

?? status == 200
{{
    test.hasResponseBody();

    const { equal } = require('assert');

    test('Workflow updated with condition branches', () => {
        const data = JSON.parse(response.body);
        equal(Array.isArray(data), true, 'Response should be an array');
        equal(data.length, 7, 'Workflow should have 7 nodes (START, Section A, Cond1, Cond2, Section B, Section C, END)');

        const startNode = data.find(n => n.id === startNodeId);
        const sectionANode = data.find(n => n.id === sectionNodeId);
        const conditionNode = data.find(n => n.id === conditionNodeId);
        const condition2Node = data.find(n => n.id === condition2NodeId);
        const sectionBNode = data.find(n => n.id === sectionBNodeId);
        const sectionCNode = data.find(n => n.id === sectionCNodeId);
        const endNode = data.find(n => n.id === endNodeId);

        equal(startNode !== undefined, true, 'START node should exist');
        equal(sectionANode !== undefined, true, 'Section A should exist');
        equal(conditionNode !== undefined, true, 'Condition 1 should exist');
        equal(condition2Node !== undefined, true, 'Condition 2 should exist');
        equal(sectionBNode !== undefined, true, 'Section B should exist');
        equal(sectionCNode !== undefined, true, 'Section C should exist');
        equal(endNode !== undefined, true, 'END node should exist');

        equal(startNode.next, sectionNodeId, 'START -> Section A');
        equal(sectionANode.next, conditionNodeId, 'Section A -> Condition 1');
        equal(conditionNode.nextTrue, sectionBNodeId, 'Condition 1 nextTrue -> Section B');
        equal(conditionNode.nextFalse, condition2NodeId, 'Condition 1 nextFalse -> Condition 2');
        equal(condition2Node.nextTrue, sectionCNodeId, 'Condition 2 nextTrue -> Section C');
        equal(condition2Node.nextFalse, endNodeId, 'Condition 2 nextFalse -> END (error handling)');
        equal(sectionBNode.next, condition2NodeId, 'Section B -> Condition 2 (so both B and C can be visited)');
        equal(sectionCNode.next, endNodeId, 'Section C -> END');

        equal(conditionNode.conditionRule !== undefined, true, 'Condition 1 should have conditionRule');
        equal(conditionNode.conditionRule.question, sectionAQuestionId, 'Condition 1 rule should reference Section A question');
        equal(conditionNode.conditionRule.pattern.includes(sectionAChoiceSectionBId), true, 'Condition 1 pattern should match choice B');
        equal(condition2Node.conditionRule !== undefined, true, 'Condition 2 should have conditionRule');
        equal(condition2Node.conditionRule.question, sectionAQuestionId, 'Condition 2 rule should reference Section A question');
        equal(condition2Node.conditionRule.pattern.includes(sectionAChoiceSectionCId), true, 'Condition 2 pattern should match choice C');

        // GET/PUT responses enrich condition labels from question title + pattern
        const sectionAQuestionTitle = 'Choose Team B / C';
        equal(
            conditionNode.label,
            `When ${sectionAQuestionTitle} matches ${sectionAChoiceSectionBId}`,
            'Condition 1 label should be enriched',
        );
        equal(
            condition2Node.label,
            `When ${sectionAQuestionTitle} matches ${sectionAChoiceSectionCId}`,
            'Condition 2 label should be enriched',
        );
    });
}}

###

# ============================================
# Get Final Workflow With Condition Branches
# ============================================
# @name getFinalWorkflowWithCondition
# @ref updateWorkflowWithConditionBranches
GET {{BASE_URL}}/forms/{{formId}}/workflow

?? status == 200
{{
    test.hasResponseBody();

    const { equal } = require('assert');

    test('Final workflow has both conditions and branches', () => {
        const data = JSON.parse(response.body);
        equal(data.workflow !== undefined, true, 'Workflow should exist');
        equal(Array.isArray(data.workflow), true, 'Workflow should be an array');
        equal(data.workflow.length, 7, 'Workflow should have 7 nodes');

        const conditionNode = data.workflow.find(n => n.id === conditionNodeId);
        const condition2Node = data.workflow.find(n => n.id === condition2NodeId);
        equal(conditionNode !== undefined, true, 'Condition 1 should be in workflow');
        equal(condition2Node !== undefined, true, 'Condition 2 should be in workflow');
        equal(conditionNode.nextTrue, sectionBNodeId, 'Condition 1 nextTrue -> Section B');
        equal(conditionNode.nextFalse, condition2NodeId, 'Condition 1 nextFalse -> Condition 2');
        equal(condition2Node.nextTrue, sectionCNodeId, 'Condition 2 nextTrue -> Section C');
        equal(condition2Node.nextFalse, endNodeId, 'Condition 2 nextFalse -> END');
        equal(conditionNode.conditionRule.question, sectionAQuestionId, 'Condition 1 references Section A question');
        equal(condition2Node.conditionRule.question, sectionAQuestionId, 'Condition 2 references Section A question');

        const sectionAQuestionTitle = 'Choose Team B / C';
        equal(
            conditionNode.label,
            `When ${sectionAQuestionTitle} matches ${sectionAChoiceSectionBId}`,
            'GET workflow: Condition 1 label should be enriched',
        );
        equal(
            condition2Node.label,
            `When ${sectionAQuestionTitle} matches ${sectionAChoiceSectionCId}`,
            'GET workflow: Condition 2 label should be enriched',
        );
    });
}}

