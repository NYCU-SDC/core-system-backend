###

# Update workflow to attach condition rule (question on temp section, nodeId = temp section)
# @name updateWorkflowWithTempConditionRule
# @ref createTempConditionForDeleteTest
PUT {{BASE_URL}}/forms/{{formId}}/workflow
Content-Type: application/json

[
    {
        "id": "{{startNodeId}}",
        "label": "開始表單",
        "payload": { "x": 0.0, "y": 0.0 },
        "next": "{{sectionNodeId}}"
    },
    {
        "id": "{{sectionNodeId}}",
        "label": "{{sectionNodeLabel}}",
        "payload": { "x": 1.0, "y": 2.0 },
        "next": "{{conditionNodeId}}"
    },
    {
        "id": "{{conditionNodeId}}",
        "label": "If choose Team B",
        "payload": { "x": 2.0, "y": 2.0 },
        "conditionRule": {
            "source": "CHOICE",
            "question": "{{sectionAQuestionId}}",
            "pattern": "{{sectionAChoiceSectionBId}}",
            "nodeId": "{{sectionNodeId}}"
        },
        "nextTrue": "{{sectionBNodeId}}",
        "nextFalse": "{{condition2NodeId}}"
    },
    {
        "id": "{{condition2NodeId}}",
        "label": "If choose Team C",
        "payload": { "x": 3.0, "y": 2.0 },
        "conditionRule": {
            "source": "CHOICE",
            "question": "{{sectionAQuestionId}}",
            "pattern": "{{sectionAChoiceSectionCId}}",
            "nodeId": "{{sectionNodeId}}"
        },
        "nextTrue": "{{sectionCNodeId}}",
        "nextFalse": "{{endNodeId}}"
    },
    {
        "id": "{{sectionBNodeId}}",
        "label": "Section B",
        "payload": { "x": 2.0, "y": 3.0 },
        "next": "{{condition2NodeId}}"
    },
    {
        "id": "{{sectionCNodeId}}",
        "label": "Section C",
        "payload": { "x": 3.0, "y": 3.0 },
        "next": "{{endNodeId}}"
    },
    {
        "id": "{{endNodeId}}",
        "label": "確認/送出",
        "payload": { "x": 0.0, "y": 1.0 }
    },
    {
        "id": "{{tempSectionNodeId}}",
        "label": "Temp Section (to delete)",
        "payload": { "x": 4.0, "y": 2.0 },
        "next": "{{tempConditionNodeId}}"
    },
    {
        "id": "{{tempConditionNodeId}}",
        "label": "Temp Condition (to delete)",
        "payload": { "x": 5.0, "y": 2.0 },
        "conditionRule": {
            "source": "NON_CHOICE",
            "question": "{{tempQuestionId}}",
            "pattern": ".*",
            "nodeId": "{{tempSectionNodeId}}"
        },
        "nextTrue": "{{endNodeId}}",
        "nextFalse": "{{endNodeId}}"
    }
]

?? status == 200
{{
    test.hasResponseBody();
    const { equal } = require('assert');
    test('Workflow updated with temp section and condition', () => {
        const data = JSON.parse(response.body);
        const tempCond = data.find(n => n.id === tempConditionNodeId);
        const tempSec = data.find(n => n.id === tempSectionNodeId);
        equal(tempCond !== undefined, true, 'Temp condition should be in workflow');
        equal(tempSec !== undefined, true, 'Temp section should be in workflow');
        equal(tempCond.conditionRule.question, tempQuestionId, 'Condition rule should reference temp section question');
        equal(tempCond.conditionRule.nodeId, tempSectionNodeId, 'Condition rule nodeId should be temp section');
    });
}}

###

# Delete the section node first (question of condition rule lives on this section)
# @name deleteTempSectionNode
# @ref updateWorkflowWithTempConditionRule
DELETE {{BASE_URL}}/forms/{{formId}}/workflow/nodes/{{tempSectionNodeId}}

?? status == 204

###

# Verify condition rule question is nil after section (and its question) was deleted
# @name verifyConditionRuleQuestionNilAfterSectionDeleted
# @ref deleteTempSectionNode
GET {{BASE_URL}}/forms/{{formId}}/workflow

?? status == 200
{{
    test.hasResponseBody();
    const { equal } = require('assert');
    test('Condition rule question is nil after referenced section deleted', () => {
        const data = JSON.parse(response.body);
        const tempCond = data.workflow.find(n => n.id === tempConditionNodeId);
        equal(tempCond !== undefined, true, 'Temp condition node should still exist');
        equal(tempCond.conditionRule !== undefined, true, 'Condition rule should exist');
        equal(tempCond.conditionRule.question, undefined, 'Condition rule question should be undefined after section (with question) was deleted');
    });
}}

###

# Delete the condition node
# @name deleteTempConditionNode
# @ref verifyConditionRuleQuestionNilAfterSectionDeleted
DELETE {{BASE_URL}}/forms/{{formId}}/workflow/nodes/{{tempConditionNodeId}}

?? status == 204