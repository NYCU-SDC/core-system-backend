# ============================================
# Workflow Condition Node with Branches
# ============================================
# Choice-option UUID validation in condition patterns is enforced on activation validation (see GET workflow `info` / publish), not necessarily on every draft PUT.
# Builds on form-lifecycle Phase 3 (03-workflow-basic). Tests condition nodes with branching:
# START -> Section A -> Condition1 (ref Section A question)
#   - choose B -> nextTrue  -> Section B -> END
#   - else      -> nextFalse -> Condition2
#     - choose C -> nextTrue  -> Section C -> END
#     - else     -> nextFalse -> END
# - Create a question in Section A (DETAILED_MULTIPLE_CHOICE) with 2 choices: Section B, Section C (else = no match → END, error handling)
# - Create Section B and Section C nodes; create two CONDITION nodes
# - Update workflow and verify structure

# Import setup from form-lifecycle Phase 3 (formId, startNodeId, endNodeId, sectionNodeId as sectionA, sectionNodeLabel as sectionALabel)
# @import ../form-lifecycle/03-workflow-basic.http

###

# ============================================
# Create Question in Section A (for condition rule)
# ============================================
# DETAILED_MULTIPLE_CHOICE: B -> Section B, C -> Section C; else (no match / error) -> END via second condition
# Condition rule CHOICE source matches selected option ID; one selection routes to B or C.
# @name createSectionAQuestion
# @ref getFinalWorkflow
POST {{BASE_URL}}/sections/{{sectionNodeId}}/questions
Content-Type: application/json

{
    "required": true,
    "type": "DETAILED_MULTIPLE_CHOICE",
    "title": "Choose Team B / C",
    "description": {
        "type": "doc",
        "content": [
            {
                "type": "paragraph",
                "content": [
                    { "type": "text", "text": "Select one to choose which section to go to" }
                ]
            }
        ]
    },
    "order": 1,
    "choices": [
        { "name": "Team B", "description": "Go to Section B" },
        { "name": "Team C", "description": "Go to Section C" }
    ]
}

?? status == 201
{{
    test.hasResponseBody();

    const { equal } = require('assert');

    test('Section A question created for condition', () => {
        const data = JSON.parse(response.body);
        equal(data.id !== undefined, true, 'Question ID should exist');
        equal(data.type, 'DETAILED_MULTIPLE_CHOICE', 'Type should be DETAILED_MULTIPLE_CHOICE');
        equal(Array.isArray(data.choices), true, 'Choices should be an array');
        equal(data.choices.length, 2, 'Should have 2 choices (Team B, Team C)');
        const hasDescriptions = data.choices.every(c => c.description !== undefined && c.description !== '');
        equal(hasDescriptions, true, 'All choices should have descriptions');
        equal(data.description?.type, 'doc', 'Description should be rich text doc');
        equal(typeof data.descriptionHtml, 'string', 'descriptionHtml should be a string');
    });

    const data = JSON.parse(response.body);
    exports.sectionAQuestionId = data.id;
    exports.sectionAChoiceSectionBId = data.choices[0].id;
    exports.sectionAChoiceSectionCId = data.choices[1].id;
}}

