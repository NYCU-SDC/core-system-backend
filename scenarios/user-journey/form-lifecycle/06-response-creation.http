###

# ============================================
# Save Draft Answers - Ranking With Other Question
# ============================================
# @name saveDraftRankingWithOtherAnswer
# @ref saveDraftRankingAnswer
PATCH {{BASE_URL}}/responses/{{responseId}}/answers
Content-Type: application/json

{
    "answers": [
        {
            "questionId": "{{rankingWithOtherQuestionId}}",
            "questionType": "RANKING",
            "value": ["{{rankingWithOtherOptions[2].id}}", "{{rankingWithOtherOptions[0].id}}", "{{rankingWithOtherOptions[1].id}}", "{{rankingWithOtherOptions[3].id}}"],
            "otherText": "Fully Distributed"
        }
    ]
}

{{
    test.status(200);
    test.hasResponseBody();

    const { equal } = require('assert');
    const data = JSON.parse(response.body);

    test('Response structure is correct', () => {
        equal(Array.isArray(data.answers), true, 'Response should have answers array');
        equal(data.answers.length, 1, 'Should have 1 answer');
        
        console.log('Saved 1 ranking-with-other answer (auto-save)');
    });

    test('Ranking with other answer content is correct', () => {
        const answer = data.answers[0];
        equal(answer !== undefined, true, 'Ranking with other answer should exist');
        equal(answer.responseId, responseId, 'Response ID should match');
        equal(answer.answer.questionId, rankingWithOtherQuestionId, 'Nested questionId should match');
        equal(answer.answer.questionType, 'RANKING', 'Question type should be RANKING');
        equal(answer.answer.value.length, 4, 'Should have 4 ranked options');
        equal(answer.answer.value[0], rankingWithOtherOptions[2].id, 'First ranked option should be Hybrid');
        equal(answer.answer.value[1], rankingWithOtherOptions[0].id, 'Second ranked option should be Remote');
        equal(answer.answer.value[2], rankingWithOtherOptions[1].id, 'Third ranked option should be On-site');
        equal(answer.answer.value[3], rankingWithOtherOptions[3].id, 'Fourth ranked option should be Other');
        equal(answer.answer.otherText, 'Fully Distributed', 'otherText should match');
        equal(answer.displayValue.includes('>'), true, 'Display value should show ranking with > separator');
        equal(answer.displayValue.includes('Fully Distributed'), true, 'Display value should include otherText');
        
        console.log('Ranking with other answer:', answer.displayValue);
    });
}}

