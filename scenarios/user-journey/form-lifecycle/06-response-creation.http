# ============================================
# Upload Files for File Upload Question
# ============================================
# @name uploadQuestionFiles
# @ref saveDraftDetailedMultipleChoiceWithOtherAnswer
POST {{BASE_URL}}/responses/{{responseId}}/questions/{{uploadFileQuestionId}}/files
Content-Type: multipart/form-data; boundary=WebKitFormBoundary

--WebKitFormBoundary
Content-Disposition: form-data; name="files"; filename="resume1.pdf"
Content-Type: application/pdf

%PDF-1.4 Mock PDF content for testing 1
--WebKitFormBoundary
Content-Disposition: form-data; name="files"; filename="resume2.pdf"
Content-Type: application/pdf

%PDF-1.4 Mock PDF content for testing 2
--WebKitFormBoundary--

{{
    test.status(201);
    test.hasResponseBody();

    const { equal } = require('assert');
    const data = JSON.parse(response.body);
    test('Files uploaded successfully', () => {
        equal(Array.isArray(data.files), true, 'Response should have a files array');
        equal(data.files.length, 2, 'Should have exactly 2 uploaded files');
    });

    test('First Uploaded file metadata is correct', () => {
        const file1 = data.files[0];
        equal(file1.fileId !== undefined, true, 'First file should have a fileId');
        equal(file1.originalFilename, 'resume1.pdf', 'First original filename should match');
        equal(file1.contentType !== undefined, true, 'First file should have a contentType');
        equal(typeof file1.size === 'number', true, 'First file size should be a number');

        console.log('First file uploaded successfully:', file1.originalFilename);
        console.log('First file ID:', file1.fileId);
    });

    test('Second Uploaded file metadata is correct', () => {
        const file2 = data.files[1];
        equal(file2.fileId !== undefined, true, 'Second file should have a fileId');
        equal(file2.originalFilename, 'resume2.pdf', 'Second original filename should match');
        equal(file2.contentType !== undefined, true, 'Second file should have a contentType');
        equal(typeof file2.size === 'number', true, 'Second file size should be a number');

        console.log('Second file uploaded successfully:', file2.originalFilename);
        console.log('Second file ID:', file2.fileId);
    });

    exports.fileIdToDelete = data.files[0].fileId;
    exports.remainingFileId = data.files[1].fileId;
    exports.remainingFileName = data.files[1].originalFilename;
    exports.remainingFileContentType = data.files[1].contentType;
    exports.remainingFileSize = data.files[1].size;
}}

