# ============================================
# Create Question 9: DETAILED_MULTIPLE_CHOICE
# ============================================
# @name createDetailedMultipleChoiceQuestion
# @ref createDropdownWithOtherQuestion
POST {{BASE_URL}}/sections/{{sectionNodeId}}/questions
Content-Type: application/json

{
    "required": true,
    "type": "DETAILED_MULTIPLE_CHOICE",
    "title": "Which technologies are you interested in?",
    "description": {
        "type": "doc",
        "content": [
            {
                "type": "paragraph",
                "content": [
                    { "type": "text", "text": "Select all areas that interest you" }
                ]
            }
        ]
    },
    "order": 9,
    "choices": [
        { 
            "name": "Frontend Development", 
            "description": "React, Vue, Angular, and modern UI frameworks" 
        },
        { 
            "name": "Backend Development", 
            "description": "Node.js, Go, Python, and server-side technologies" 
        },
        { 
            "name": "DevOps", 
            "description": "CI/CD, Docker, Kubernetes, cloud infrastructure" 
        },
        { 
            "name": "Data Science", 
            "description": "Machine learning, data analysis, and AI" 
        }
    ]
}

{{
    test.status(201);
    test.hasResponseBody();

    const { equal, deepStrictEqual } = require('assert');

    test('Detailed multiple choice question created', () => {
        const data = JSON.parse(response.body);
        equal(data.id !== undefined, true, 'Question ID should exist');
        equal(data.type, 'DETAILED_MULTIPLE_CHOICE', 'Type should be DETAILED_MULTIPLE_CHOICE');
        equal(data.sectionId, sectionNodeId, 'Section ID should match');
        equal(Array.isArray(data.choices), true, 'Choices should be an array');
        equal(data.choices.length, 4, 'Should have 4 choices');
        equal(data.description?.type, 'doc', 'Description should be rich text doc');
        deepStrictEqual(
            data.description?.content?.[0],
            {
                type: 'paragraph',
                content: [{ type: 'text', text: 'Select all areas that interest you' }],
            },
            'Description paragraph should match request',
        );

        // Verify descriptions exist
        const hasDescriptions = data.choices.every(c => c.description !== undefined && c.description !== '');
        equal(hasDescriptions, true, 'All choices should have descriptions');
        
        console.log('Created DETAILED_MULTIPLE_CHOICE question:', data.id);
    });

    const data = JSON.parse(response.body);
    exports.detailedMultipleChoiceQuestionId = data.id;
    exports.detailedMultipleChoiceOptions = data.choices;
}}

###

# ============================================
# Create Question 10: DETAILED_MULTIPLE_CHOICE_WITH_OTHER
# ============================================
# @name createDetailedMultipleChoiceWithOtherQuestion
# @ref createDetailedMultipleChoiceQuestion
POST {{BASE_URL}}/sections/{{sectionNodeId}}/questions
Content-Type: application/json

{
    "required": true,
    "type": "DETAILED_MULTIPLE_CHOICE",
    "title": "Which technologies are you interested in?",
    "description": {
        "type": "doc",
        "content": [
            {
                "type": "paragraph",
                "content": [
                    { "type": "text", "text": "Select all areas that interest you" }
                ]
            }
        ]
    },
    "order": 10,
    "choices": [
        { 
            "name": "Frontend Development", 
            "description": "React, Vue, Angular, and modern UI frameworks" 
        },
        { 
            "name": "Backend Development", 
            "description": "Node.js, Go, Python, and server-side technologies" 
        },
        { 
            "name": "DevOps", 
            "description": "CI/CD, Docker, Kubernetes, cloud infrastructure" 
        },
        { 
            "name": "Data Science", 
            "description": "Machine learning, data analysis, and AI" 
        },
        {
            "name": "",
            "description": "",
            "isOther": true
        }
    ]
}

{{
    test.status(201);
    test.hasResponseBody();

    const { equal, deepStrictEqual } = require('assert');

    test('Detailed multiple choice question created', () => {
        const data = JSON.parse(response.body);
        equal(data.id !== undefined, true, 'Question ID should exist');
        equal(data.type, 'DETAILED_MULTIPLE_CHOICE', 'Type should be DETAILED_MULTIPLE_CHOICE');
        equal(data.sectionId, sectionNodeId, 'Section ID should match');
        equal(Array.isArray(data.choices), true, 'Choices should be an array');
        equal(data.choices.length, 5, 'Should have 5 choices');
        equal(data.description?.type, 'doc', 'Description should be rich text doc');
        deepStrictEqual(
            data.description?.content?.[0],
            {
                type: 'paragraph',
                content: [{ type: 'text', text: 'Select all areas that interest you' }],
            },
            'Description paragraph should match request',
        );

        // Verify descriptions exist
        const hasDescriptions = data.choices.every(c => c.isOther || (c.description !== undefined && c.description !== ''));
        equal(hasDescriptions, true, 'All choices other than "Other" should have descriptions');
        
        console.log('Created DETAILED_MULTIPLE_CHOICE question with other option:', data.id);
    });

    const data = JSON.parse(response.body);
    exports.detailedMultipleChoiceWithOtherQuestionId = data.id;
    exports.detailedMultipleChoiceWithOtherOptions = data.choices;
}}

