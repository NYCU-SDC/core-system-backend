# ============================================
# Swap two question orders (1 and 2)
# ============================================
# Put SHORT_TEXT at order 2 and LONG_TEXT at order 1.
# @name swapTwoQuestionOrders
# @ref updateShortTextQuestion
PUT {{BASE_URL}}/sections/{{sectionNodeId}}/questions/{{shortTextQuestionId}}
Content-Type: application/json

{
    "required": false,
    "type": "SHORT_TEXT",
    "title": "What is your full name? (Updated)",
    "description": {
        "type": "doc",
        "content": [
            {
                "type": "paragraph",
                "content": [
                    { "type": "text", "text": "Please enter your " },
                    { "type": "text", "marks": [{ "type": "bold" }], "text": "first and last name" },
                    { "type": "text", "text": " - this field is now " },
                    { "type": "text", "marks": [{ "type": "italic" }], "text": "optional" },
                    { "type": "text", "text": ". See " },
                    { "type": "text", "marks": [{ "type": "link", "attrs": { "href": "https://example.com/profile" } }], "text": "profile" },
                    { "type": "text", "text": "." }
                ]
            }
        ]
    },
    "order": 2
}

{{
    test.status(200);
    test.hasResponseBody();

    const { equal, deepStrictEqual } = require('assert');
    const data = JSON.parse(response.body);

    test('Short text question description unchanged after order swap', () => {
        equal(data.description?.type, 'doc', 'Description should be rich text doc');
        deepStrictEqual(
            data.description?.content?.[0],
            {
                type: 'paragraph',
                content: [
                    {
                        type: 'text',
                        text: 'Please enter your ',
                    },
                    {
                        type: 'text',
                        marks: [{ type: 'bold' }],
                        text: 'first and last name',
                    },
                    {
                        type: 'text',
                        text: ' - this field is now ',
                    },
                    {
                        type: 'text',
                        marks: [{ type: 'italic' }],
                        text: 'optional',
                    },
                    {
                        type: 'text',
                        text: '. See ',
                    },
                    {
                        type: 'text',
                        marks: [{ type: 'link', attrs: { href: 'https://example.com/profile' } }],
                        text: 'profile',
                    },
                    {
                        type: 'text',
                        text: '.',
                    },
                ],
            },
            'Description paragraph should still match after order change',
        );
    });
}}


###

# ============================================
# Verify question order after swap (1=LONG_TEXT, 2=SHORT_TEXT)
# ============================================
# @name verifyQuestionOrderAfterSwap
# @ref swapTwoQuestionOrders
GET {{BASE_URL}}/forms/{{formId}}/sections

{{
    test.status(200);
    test.hasResponseBody();

    const { equal, deepStrictEqual } = require('assert');

    test('Question order after swap is correct', () => {
        const data = JSON.parse(response.body);
        const ourSection = data.find(s => s.section.id === sectionNodeId);
        equal(ourSection !== undefined, true, 'Our section should exist');
        const questions = ourSection.questions.slice().sort((a, b) => a.order - b.order);
        equal(questions[0].id, longTextQuestionId, 'Order 1 should be LONG_TEXT');
        equal(questions[1].id, shortTextQuestionId, 'Order 2 should be SHORT_TEXT');
        const longTextQ = questions.find((q) => q.id === longTextQuestionId);
        equal(longTextQ.description?.type, 'doc', 'LONG_TEXT listed description should be rich text doc');
        deepStrictEqual(
            longTextQ.description?.content?.[0],
            {
                type: 'paragraph',
                content: [
                    {
                        type: 'text',
                        text: 'Please share your educational background and work experience (maximum 500 words)',
                    },
                ],
            },
            'LONG_TEXT description paragraph should match',
        );
    });
}}

