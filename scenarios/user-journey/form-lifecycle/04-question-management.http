# ============================================
# Update Question - Test Update Operation
# ============================================
# @name updateShortTextQuestion
# @ref listQuestionsInSection
PUT {{BASE_URL}}/sections/{{sectionNodeId}}/questions/{{shortTextQuestionId}}
Content-Type: application/json

{
    "required": false,
    "type": "SHORT_TEXT",
    "title": "What is your full name? (Updated)",
    "description": {
        "type": "doc",
        "content": [
            {
                "type": "paragraph",
                "content": [
                    { "type": "text", "text": "Please enter your " },
                    { "type": "text", "marks": [{ "type": "bold" }], "text": "first and last name" },
                    { "type": "text", "text": " - this field is now " },
                    { "type": "text", "marks": [{ "type": "italic" }], "text": "optional" },
                    { "type": "text", "text": ". See " },
                    { "type": "text", "marks": [{ "type": "link", "attrs": { "href": "https://example.com/profile" } }], "text": "profile" },
                    { "type": "text", "text": "." }
                ]
            }
        ]
    },
    "order": 1
}

{{
    test.status(200);
    test.hasResponseBody();

    const { equal, deepStrictEqual } = require('assert');

    test('Question updated successfully', () => {
        const data = JSON.parse(response.body);
        equal(data.id, shortTextQuestionId, 'Question ID should match');
        equal(data.type, 'SHORT_TEXT', 'Type should remain SHORT_TEXT');
        equal(data.title, 'What is your full name? (Updated)', 'Title should be updated');
        equal(data.required, false, 'Required should be updated to false');
        equal(data.sectionId, sectionNodeId, 'Section ID should match');
        equal(data.description?.type, 'doc', 'Description should be rich text doc');
        equal(typeof data.descriptionHtml, 'string', 'descriptionHtml should be a string');

        const html = data.descriptionHtml;
        equal(html.includes('<strong>'), true, 'descriptionHtml should render strong');
        equal(html.includes('<em>'), true, 'descriptionHtml should render em');
        equal(html.includes('<a'), true, 'descriptionHtml should render link');
        equal(html.includes('https://example.com/profile'), true, 'descriptionHtml should include link href');
        deepStrictEqual(
            data.description?.content?.[0],
            {
                type: 'paragraph',
                content: [
                    {
                        type: 'text',
                        text: 'Please enter your ',
                    },
                    {
                        type: 'text',
                        marks: [{ type: 'bold' }],
                        text: 'first and last name',
                    },
                    {
                        type: 'text',
                        text: ' - this field is now ',
                    },
                    {
                        type: 'text',
                        marks: [{ type: 'italic' }],
                        text: 'optional',
                    },
                    {
                        type: 'text',
                        text: '. See ',
                    },
                    {
                        type: 'text',
                        marks: [{ type: 'link', attrs: { href: 'https://example.com/profile' } }],
                        text: 'profile',
                    },
                    {
                        type: 'text',
                        text: '.',
                    },
                ],
            },
            'Updated description paragraph should match request',
        );

        console.log('Updated question:', data.id);
    });
}}

