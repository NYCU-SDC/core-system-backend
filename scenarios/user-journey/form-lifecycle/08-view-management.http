###

# ============================================
# Duplicate View (should be inserted after original)
# ============================================
# @name duplicateFirstView
# @ref unlockSecondView
POST {{BASE_URL}}/forms/{{formId}}/views/{{firstViewId}}/duplicate

{{
    test.status(201);
    test.hasResponseBody();

    const { equal } = require('assert');

    test('View duplicated with correct title and order', () => {
        const data = JSON.parse(response.body);
        equal(data.id !== undefined, true, 'Duplicated view ID should exist');
        equal(data.id !== firstViewId, true, 'Duplicated view should have a new ID');
        equal(data.title, '「Core System」的副本', 'Duplicated view title should have suffix');
        equal(data.locked, false, 'Duplicated view should not be locked');
        equal(data.order, 3, 'Duplicated view should be placed after original (order 2 + 1 = 3)');
        equal(data.formId, formId, 'Form ID should match');
    });

    const data = JSON.parse(response.body);
    exports.duplicatedViewId = data.id;
}}

###

# ============================================
# Verify list after duplicate (duplicated view is right after original)
# ============================================
# @name verifyListAfterDuplicate
# @ref duplicateFirstView
GET {{BASE_URL}}/forms/{{formId}}/views

{{
    test.status(200);
    test.hasResponseBody();

    const { equal } = require('assert');

    test('Duplicated view is placed immediately after original', () => {
        const data = JSON.parse(response.body);
        equal(data.length, 4, 'Should now have 4 views');

        const views = data.slice().sort((a, b) => a.order - b.order);
        const originalIndex = views.findIndex(v => v.id === firstViewId);
        const duplicateIndex = views.findIndex(v => v.id === duplicatedViewId);
        equal(duplicateIndex, originalIndex + 1, 'Duplicate should be immediately after original');
    });
}}

###

# ============================================
# Duplicate First View Again (should generate incremented copy title)
# ============================================
# @name duplicateFirstViewAgain
# @ref verifyListAfterDuplicate
POST {{BASE_URL}}/forms/{{formId}}/views/{{firstViewId}}/duplicate

{{
    test.status(201);
    test.hasResponseBody();

    const { equal } = require('assert');

    test('Second duplicate of same view gets incremented title', () => {
        const data = JSON.parse(response.body);
        equal(data.id !== undefined, true, 'Duplicated view ID should exist');
        equal(data.id !== firstViewId, true, 'Duplicated view should have a new ID');
        equal(data.id !== duplicatedViewId, true, 'Should be a different view from first duplicate');
        equal(data.title, '「Core System」的副本（1）', 'Second duplicate title should have numeric suffix');
        equal(data.locked, false, 'Duplicated view should not be locked');
        equal(data.formId, formId, 'Form ID should match');
    });

    const data = JSON.parse(response.body);
    exports.duplicatedViewId2 = data.id;
}}

###

# ============================================
# Verify list after second duplicate
# ============================================
# @name verifyListAfterSecondDuplicate
# @ref duplicateFirstViewAgain
GET {{BASE_URL}}/forms/{{formId}}/views

{{
    test.status(200);
    test.hasResponseBody();

    const { equal } = require('assert');

    test('Both duplicates are present and placed after original', () => {
        const data = JSON.parse(response.body);
        equal(data.length, 5, 'Should now have 5 views');

        // Verify exact order values for each view
        const secondView = views.find(v => v.id === secondViewId);
        const thirdView = views.find(v => v.id === thirdViewId);
        const firstView = views.find(v => v.id === firstViewId);
        const dup2View = views.find(v => v.id === duplicatedViewId2);
        const dup1View = views.find(v => v.id === duplicatedViewId);
        equal(secondView.order, 0, 'Second view should have order 0');
        equal(thirdView.order, 1, 'Third view should have order 1');
        equal(firstView.order, 2, 'First view should have order 2');
        equal(dup2View.order, 3, 'Second duplicate should have order 3 (inserted right after original)');
        equal(dup1View.order, 4, 'First duplicate should have order 4 (pushed up by second duplicate)');
    });
}}

###

# ============================================
# Delete View
# ============================================
# @name deleteThirdView
# @ref verifyListAfterSecondDuplicate
DELETE {{BASE_URL}}/forms/{{formId}}/views/{{thirdViewId}}

{{
    test.status(204);

    console.log('Deleted view:', thirdViewId);
}}

###

# ============================================
# Verify deletion (third view no longer in list)
# ============================================
# @name verifyViewDeletion
# @ref deleteThirdView
GET {{BASE_URL}}/forms/{{formId}}/views

{{
    test.status(200);
    test.hasResponseBody();

    const { equal } = require('assert');

    test('Deleted view is no longer in list', () => {
        const data = JSON.parse(response.body);
        equal(data.length, 4, 'Should now have 4 views');
        equal(data.some(v => v.id === thirdViewId), false, 'Deleted view should not appear in list');
    });
}}
